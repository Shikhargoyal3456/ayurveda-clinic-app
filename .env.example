# Copy this file to .env and fill in your real values
# Never commit .env to GitHub

# App
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-strong-random-key-here
CLINIC_NAME=Kash AI
APP_NAME=Kash AI
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./ayurveda.db

# Security
SESSION_HTTPS_ONLY=false
HTTPS_REDIRECT_ENABLED=false
ADMIN_USERNAMES=admin@yourdomain.com
ALLOW_PUBLIC_SIGNUP=true

# AI — Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# AI — Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AI — Google Speech-to-Text
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key_here

# Google Maps — Places & Distance Matrix
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AI settings
AI_ENABLED=true
STARTUP_RAG_WARMUP=false
STARTUP_LLM_WARMUP=false

# WhatsApp — Meta Cloud API (optional)
# Keep the real values only in your local `.env`, never in source files.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en_US
