# Copy this file to .env and fill in your real values
# Never commit .env to GitHub

# App
ENVIRONMENT=production
SENTRY_DSN=https://o123.ingest.sentry.io/YOUR_KEY
DEBUG=true
SECRET_KEY=generate-a-strong-random-key-here
CLINIC_NAME=Kash AI
APP_NAME=Kash AI
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./ayurveda.db?cache=shared&timeout=30
REDIS_URL=redis://localhost:6379/0

# Security
SESSION_HTTPS_ONLY=true
HTTPS_REDIRECT_ENABLED=false
ADMIN_USERNAMES=admin@yourdomain.com
ALLOW_PUBLIC_SIGNUP=true
# REPLACE WITH YOUR DOMAIN before deploy
TRUSTED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,localhost

# AI — Vertex AI Gemini
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# Authenticate locally with: gcloud auth application-default login
# Optional fallback used in code if the configured model is unavailable: gemini-2.5-flash-exp

# AI — Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AI — Google Speech-to-Text
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key_here

# Google Maps — Places & Distance Matrix
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Payments — Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_MODE=test
CLOUD_RUN_MEMORY=512Mi
CLOUD_RUN_CONCURRENCY=80

# Optional integrations — default to mock/off for safe rollout
ENABLE_SUPPLIER_API=false
ENABLE_DELIVERY_API=false
ENABLE_SMART_PRICING=false
SUPPLIER_API_URL=
DELIVERY_API_URL=

# AI settings
AI_ENABLED=true
STARTUP_RAG_WARMUP=false
STARTUP_LLM_WARMUP=false

# WhatsApp — Meta Cloud API (optional)
# Keep the real values only in your local `.env`, never in source files.
# POLISH-8-WHATSAPP-UPDATES: Keep false in dev; set true only after Meta Cloud API is configured.
ENABLE_WHATSAPP_API=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v23.0
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en_US

# Email — Gmail SMTP (optional)
EMAIL_USER=
EMAIL_PASSWORD=

# Node WhatsApp prescription service — Twilio + Vertex AI + Redis + SQLite
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PRESCRIPTION_CONTENT_SID=
SQLITE_DB_PATH=./data/whatsapp_notifications.sqlite
# React Native / Expo live doctor keys
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
EXPO_PUBLIC_AI_DOCTOR_WS_URL=ws://35.244.0.89:8000/ws/ai-doctor
